"""Celery application for {{ project_name }}, generated by dsd-cloudron.

The worker and beat supervisor programs run `celery -A {{ project_name }}`, which
imports this module. The broker and result backend come from CLOUDRON_REDIS_URL,
wired in cloudron_settings.py.
"""

import os

from celery import Celery

os.environ.setdefault("DJANGO_SETTINGS_MODULE", "{{ project_name }}.settings")

app = Celery("{{ project_name }}")
app.config_from_object("django.conf:settings", namespace="CELERY")
app.autodiscover_tasks()
